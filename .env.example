# Скопируй в .env и заполни нужные значения:
#   cp .env.example .env

# ── Аутентификация ──────────────────────────────────────────
# Токены через запятую. Если не задано — auth отключена.
# VOIREC_API_KEYS=token1,token2

# Или файл с токенами (по одному на строку). Приоритет над VOIREC_API_KEYS.
# VOIREC_API_KEYS_FILE=/run/secrets/api_keys

# ── Сервер ──────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
